{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hostpilot",
  "version": "0.1.0",
  "identifier": "com.hostpilot.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "hostpilot",
        "width": 1100,
        "height": 720,
        "minWidth": 1100,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "hostpilot",
        "width": 500,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "visible": true,
        "center": true,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
