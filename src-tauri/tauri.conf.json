{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Host Pilot",
  "version": "0.1.1",
  "identifier": "com.hostpilot.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Host Pilot",
        "width": 1100,
        "height": 720,
        "minWidth": 1100,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Host Pilot",
        "width": 500,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "visible": true,
        "center": true,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxMTc0MDkwRDQwQzFDQUQKUldTdEhBelVrRUFYWVptVzEvU2VMMTJFaTJZd3pwR3RFYlJkTys5akFqZWFzbFl6Mnl1QzZDK3gK",
      "endpoints": [
        "https://github.com/ChilG/hostpilot/releases/latest/download/latest.json"
      ]
    }
  }
}
